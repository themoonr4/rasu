<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>THE MOON - API Documentation</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        *{margin:0;padding:0;box-sizing:border-box;}
        body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#0a0a0a;color:#fff;padding:2rem;}
        [data-theme="light"]{background:#f5f5f5;color:#1a1a1a;}
        .container{max-width:800px;margin:0 auto;}
        h1{margin-bottom:1rem;color:#dc2626;}
        .card{background:#111;border:1px solid #222;border-radius:16px;padding:1.5rem;margin-bottom:1rem;}
        .endpoint{background:#1a1a1a;border-radius:12px;padding:1rem;margin-bottom:1rem;}
        .method{display:inline-block;padding:0.2rem 0.5rem;border-radius:4px;font-size:0.7rem;font-weight:bold;margin-right:0.5rem;}
        .get{background:#28a745;}
        .post{background:#dc2626;}
        .put{background:#ffc107;color:#000;}
        .delete{background:#dc3545;}
        .code-block{background:#0a0a0a;padding:0.5rem;border-radius:8px;font-family:monospace;font-size:0.7rem;margin-top:0.5rem;}
        button{background:#dc2626;color:white;border:none;padding:0.25rem 0.5rem;border-radius:4px;cursor:pointer;}
        .back-btn{display:inline-flex;align-items:center;gap:0.5rem;background:transparent;border:1px solid #333;padding:0.5rem 1rem;border-radius:8px;margin-bottom:1rem;cursor:pointer;}
    </style>
</head>
<body>
    <div class="container">
        <div class="back-btn" onclick="location.href='/admin.html'"><i class="fas fa-arrow-left"></i> Back</div>
        <h1><i class="fas fa-code"></i> Interactive API Documentation</h1>
        
        <div class="card">
            <h3>Authentication</h3>
            <div class="code-block">Headers: { "apikey": "YOUR_API_KEY", "Authorization": "Bearer YOUR_TOKEN" }</div>
        </div>
        
        <div class="endpoint">
            <div><span class="method get">GET</span> <code>/api/news</code><button onclick="testEndpoint('/api/news')" style="margin-left:0.5rem;">Try It</button></div>
            <div class="code-block" id="result1"></div>
        </div>
        
        <div class="endpoint">
            <div><span class="method get">GET</span> <code>/api/news/:id</code><button onclick="testEndpoint('/api/news/1')" style="margin-left:0.5rem;">Try It</button></div>
            <div class="code-block" id="result2"></div>
        </div>
        
        <div class="endpoint">
            <div><span class="method get">GET</span> <code>/api/categories</code><button onclick="testEndpoint('/api/categories')" style="margin-left:0.5rem;">Try It</button></div>
            <div class="code-block" id="result3"></div>
        </div>
        
        <div class="endpoint">
            <div><span class="method post">POST</span> <code>/api/admin/news</code><button onclick="showPostForm()" style="margin-left:0.5rem;">Try It</button></div>
            <div id="postForm" style="display:none; margin-top:0.5rem;">
                <input type="text" id="postTitle" placeholder="Title" style="width:100%;padding:0.25rem;margin-bottom:0.25rem;">
                <textarea id="postContent" placeholder="Content" rows="3" style="width:100%;padding:0.25rem;"></textarea>
                <button onclick="testPostEndpoint()">Send POST</button>
            </div>
            <div class="code-block" id="result4"></div>
        </div>
    </div>
    <script>
        async function testEndpoint(url) {
            const resultDiv = url === '/api/news' ? document.getElementById('result1') : 
                              url === '/api/news/1' ? document.getElementById('result2') : 
                              document.getElementById('result3');
            resultDiv.innerHTML = '<span style="color:#ffc107;">Loading...</span>';
            try {
                const res = await fetch(url);
                const data = await res.json();
                resultDiv.innerHTML = JSON.stringify(data, null, 2);
            } catch(e) {
                resultDiv.innerHTML = `<span style="color:#dc3545;">Error: ${e.message}</span>`;
            }
        }
        
        function showPostForm() { document.getElementById('postForm').style.display = 'block'; }
        
        async function testPostEndpoint() {
            const title = document.getElementById('postTitle').value;
            const content = document.getElementById('postContent').value;
            const resultDiv = document.getElementById('result4');
            resultDiv.innerHTML = '<span style="color:#ffc107;">Sending...</span>';
            try {
                const res = await fetch('/api/admin/news', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title, content }) });
                const data = await res.json();
                resultDiv.innerHTML = JSON.stringify(data, null, 2);
            } catch(e) {
                resultDiv.innerHTML = `<span style="color:#dc3545;">Error: ${e.message}</span>`;
            }
        }
        
        if (localStorage.getItem('theme') === 'light') document.body.setAttribute('data-theme', 'light');
    </script>
</body>
</html>
